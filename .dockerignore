# =============================================================================
# .dockerignore for agno-config
# Excludes unnecessary files from Docker build context
# =============================================================================

# -----------------------------------------------------------------------------
# Version control
# -----------------------------------------------------------------------------
.git
.gitignore

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__
*.py[codz]
*$py.class
*.so
.venv
venv
env
*.egg-info
dist
build
.mypy_cache
.pyre
.pytype
.ruff_cache

# Python databases (will be created at runtime in /app/data)
*.db

# -----------------------------------------------------------------------------
# Node.js / Next.js
# -----------------------------------------------------------------------------
agent-ui/node_modules
agent-ui/.next
agent-ui/out
agent-ui/.pnp
agent-ui/.pnp.*
agent-ui/.yarn
agent-ui/coverage
agent-ui/.vercel
agent-ui/.tsbuildinfo
agent-ui/next-env.d.ts

# -----------------------------------------------------------------------------
# Documentation and misc
# -----------------------------------------------------------------------------
README.md
LICENSE
*.md
!agent-ui/README.md

# -----------------------------------------------------------------------------
# Docker files (no need to include themselves)
# -----------------------------------------------------------------------------
Dockerfile
docker-compose.yml
.dockerignore

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Desktop.ini
Thumbs.db

# -----------------------------------------------------------------------------
# Environment files (secrets should be passed at runtime)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
