# Model (VLLM)
VLLM_BASE_URL=http://your-vllm-host:8001/v1
VLLM_API_KEY=

# Atlassian — Confluence
CONFLUENCE_URL=https://your-confluence.example.com
CONFLUENCE_USERNAME=your_email@example.com
CONFLUENCE_PERSONAL_TOKEN=

# Atlassian — Jira
JIRA_URL=https://your-jira.example.com/
JIRA_USERNAME=your_email@example.com
JIRA_PERSONAL_TOKEN=

# GitLab
GITLAB_API_URL=https://your-gitlab.example.com
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_READ_ONLY_MODE=false
USE_GITLAB_WIKI=false
USE_MILESTONE=false
USE_PIPELINE=true

# Document Parser (MCP)
MCP_PARSER_URL=http://your-parser-host:8300/mcp

# Database
DB_DIR=/app/data

# Port mapping (host:container is PORT:80)
PORT=3000
